/dts-v1/;
#include <st/f0/stm32f091Xc.dtsi>
#include <st/f0/stm32f091r(b-c)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "Oresat battery card";
	compatible = "st,stm32f091rc-nucleo";

	chosen {
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &can1;
	};

	leds: leds {
		compatible = "gpio-leds";

		amber_led_1: led_1 {
			gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;
			label = "Heartbeat LED";
			status = "okay";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_button: button {
			label = "User";
			gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
			status = "disabled";
		};
	};

	pwmleds: pwmleds {
		compatible = "pwm-leds";
		status = "disabled";

		amber_pwm_led: amber_pwm_led {
			pwms = <&pwm2 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
	};

	battpacks: oresat_battery_packs {
		compatible = "battery-packs";
		#gpio-cells = <2>;
		alert-gpios = <&gpiob 5 0>, <&gpiob 12 0>;
		charge-stat-oc-gpios = <&gpioa 7 0>, <&gpiob 10 0>;
		discharge-stat-oc-gpios = <&gpioa 1 0>, <&gpiob 11 0>;
		charge-disable-gpios = <&gpioa 4 GPIO_ACTIVE_HIGH>, <&gpiob 0 GPIO_ACTIVE_HIGH>;
		discharge-disable-gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>, <&gpiob 1 GPIO_ACTIVE_HIGH>;
		heater-gpios = <&gpioc 14 GPIO_ACTIVE_HIGH>, <&gpioc 15 GPIO_ACTIVE_HIGH>;
		moarpwr-gpios = <&gpiob 15 GPIO_ACTIVE_HIGH>;
		can-shutdown-gpios = <&gpioa 10 GPIO_ACTIVE_HIGH>;
		can-silent-gpios = <&gpioa 9 GPIO_ACTIVE_HIGH>;
	};

	aliases {
		led0 = &amber_led_1;
		sw0 = &user_button;
		pwm-led0 = &amber_pwm_led;
		watchdog0 = &iwdg;
		die-temp0 = &die_temp;
		volt-sensor0 = &vref;
		volt-sensor1 = &vbat;
	};
};

&clk_hse {
        /delete-property/ hse-bypass;
        clock-frequency = <DT_FREQ_M(16)>; // ERS board 16MHz crystal
        status = "okay";
};

&clk_lsi {
        status = "okay";
};

&pll {
        prediv = <1>;
        mul = <3>;
        clocks = <&clk_hse>;
        status = "okay";
};

&rcc {
        clocks = <&pll>;
        clock-frequency = <DT_FREQ_M(48)>;
        ahb-prescaler = <1>;
        apb1-prescaler = <1>;
        status = "okay";
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pb6 &usart1_rx_pb7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	pack1: max17205@36 {
		compatible = "maxim,max17205";
		reg = <0x36>;
		/* NOTE: this device has two I2C slave addresses. They are used to access
		 * different sets of register addresses. Ensure your system does not place
		 * another device on the I2C bus which responds to the below aux-addr.
		 */
		aux-addr = <0x0b>;
		num-cells = <2>;
		cell-bal-thresh-voltage = <40>;
		pack-flags = <0x3e00>;
		rsense-mohms = <10>;
		config = <0x0211>;
		status = "okay";
	};
};

&i2c2 {
	/* Pin conflict with can1. Enable only with can1 disabled. */
	pinctrl-0 = <&i2c2_scl_pb13 &i2c2_sda_pb14>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	pack2: max17205@36 {
		compatible = "maxim,max17205";
		reg = <0x36>;
		/* NOTE: this device has two I2C slave addresses. They are used to access
		 * different sets of register addresses. Ensure your system does not place
		 * another device on the I2C bus which responds to the below aux-addr.
		 */
		aux-addr = <0x0b>;
		num-cells = <2>;
		cell-bal-thresh-voltage = <40>;
		pack-flags = <0x3e00>;
		rsense-mohms = <10>;
		config = <0x0211>;
		status = "okay";
	};
};


&can1 {
	pinctrl-0 = <&can_rx_pa11 &can_tx_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	status = "disabled";
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
	pinctrl-names = "default";
	status = "disabled";
};

&iwdg {
	status = "okay";
};

&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x10000000>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Set 8Kb of storage just before storage_partition defined below */
		hist_partition: partition@3e000 {
			label = "hist";
			reg = <0x0003e000 DT_SIZE_K(8)>;
		};
		/* Set 4Kb of storage at the end of the 256Kb of flash */
		/*storage_partition: partition@3f000 {
			label = "storage";
			reg = <0x0003f000 DT_SIZE_K(4)>;
		};*/
	};
};

&adc1 {
	//pinctrl-0 = <&adc_in6_pa6>; /* currently routed to pa8, which is not ADC-capable */
	//pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <2>;
	status = "okay"; /* disable for now */
};

&die_temp {
	status = "okay";
};

&dac1 {
	status = "disabled";
	pinctrl-0 = <&dac_out1_pa4>;
	pinctrl-names = "default";
};

&dma1 {
	status = "okay";
};

&timers2 {
	st,prescaler = <10000>;
	status = "disabled";

	pwm2: pwm {
		/* NOTE: disabled by default, PWM2 conflicts with SPI1 */
		pinctrl-0 = <&tim2_ch1_pa0>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&vref {
	status = "okay";
};

&vbat {
	status = "okay";
};
